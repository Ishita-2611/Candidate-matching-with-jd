GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

INPUT_JSONL=candidates.jsonl
BATCH_LIMIT=5
START_OFFSET=0
CONCURRENCY=1
OUTPUT_BATCH_SIZE=5
OUTPUT_DIR=batches

BATCHES_DIR=batches_finetuned_1-20k
EMBED_LIMIT=5
EMBEDDING_MODEL=Xenova/bge-m3
EMBEDDING_DIM=1024
TRANSFORMERS_CACHE=./model_cache

QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_cloud_api_key_here
QDRANT_COLLECTION=candidate_semantic_multivectors_bge_m3
QDRANT_UPSERT_BATCH_SIZE=4

JD_SEMANTIC_FILE=jd-semantic.json
JD_EMBEDDINGS_FILE=jd-embeddings.json
SEARCH_LIMIT=100
SEARCH_RECALL_LIMIT=500

RAG_LIMIT=100
RAG_RECALL_LIMIT=500
RAG_OUTPUT_JSON=rag-results.json
RAG_OUTPUT_CSV=rag-submission.csv
RAG_EXPLANATION_PROVIDER=local
RAG_EXPLAIN_LIMIT=100
RAG_EXPLANATION_CONCURRENCY=3

RERANKER_ENABLED=true
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512
RERANKER_WEIGHT=0.7
RERANKER_VECTOR_WEIGHT=0.15
RERANKER_SKILL_WEIGHT=0.075
RERANKER_BUSINESS_WEIGHT=0.075
RERANKER_DISQUALIFIER_PENALTY=0.15
RERANKER_HONEYPOT_PENALTY=0.1

FINETUNE_CANDIDATES_FILE=candidates.jsonl
FINETUNE_SEMANTIC_DIR=batches_finetuned_1-20k
FINETUNE_OUTPUT_DIR=fine_tuning
FINETUNE_LIMIT=1000
FINETUNE_VALIDATION_RATIO=0.1

FINETUNED_API_KEY=your_finetuned_provider_key_here
FINETUNED_BASE_URL=https://app.openpipe.ai/api/v1
FINETUNED_MODEL=openpipe:cruel-cooks-search
FINETUNED_INPUT_JSONL=candidates.jsonl
FINETUNED_OUTPUT_DIR=batches_finetuned
FINETUNED_START_OFFSET=0
FINETUNED_LIMIT=1000
FINETUNED_OUTPUT_BATCH_SIZE=100
FINETUNED_CONCURRENCY=3
