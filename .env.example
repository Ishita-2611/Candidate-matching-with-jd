GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

INPUT_JSONL=candidates.jsonl
BATCH_LIMIT=5
START_OFFSET=0
CONCURRENCY=1
OUTPUT_BATCH_SIZE=5
OUTPUT_DIR=batches

BATCHES_DIR=batches
EMBED_LIMIT=5
EMBEDDING_MODEL=Xenova/bge-m3
EMBEDDING_DIM=1024
TRANSFORMERS_CACHE=./model_cache

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=candidate_semantic_multivectors_bge_m3
QDRANT_UPSERT_BATCH_SIZE=4
